# --- CONFIGURATION POINTEUSE PRO ---

# 1. Base de données
# Laissez vide pour SQLite (local). Pour Render, utilisez la DATABASE_URL fournie par Render.
DATABASE_URL=

# 2. Cloudinary (Obligatoire pour les photos en ligne)
CLOUDINARY_URL=
# Ou via clés individuelles :
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 3. Email (SMTP) - Pour l'envoi des rapports PDF
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application

# 4. Monitoring (Optionnel)
SENTRY_DSN=

# 5. Serveur
PORT=5001
